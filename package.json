{
	"name": "svelte-electron",
	"description": "Electron shell for a SvelteKit app served with adapter-node",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "electron/main.js",
	"scripts": {
		"dev": "concurrently -k -s first \"npm:dev:sveltekit\" \"npm:dev:electron\"",
		"dev:sveltekit": "vite dev --host 127.0.0.1 --port 4173",
		"dev:electron": "wait-on tcp:4173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:4173 electron .",
		"build": "vite build",
		"start": "npm run build && electron .",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^41.2.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wait-on": "^9.0.5"
	}
}
